# Database
# 开发环境使用 SQLite，生产环境使用 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./ai_trainer.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_trainer

# JWT
SECRET_KEY=change-me-in-production

# AI Service (通义千问)
# 获取 API Key: https://dashscope.console.aliyun.com/
AI_API_KEY=your-api-key-here
AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-vl-max

# SMS (短信服务)
SMS_API_KEY=
SMS_SECRET=

# App
DEBUG=true
UPLOAD_DIR=./uploads
